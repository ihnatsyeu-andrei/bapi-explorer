# ── Connection type ───────────────────────────────────────────────────────────
# SAP_CONN_TYPE=direct   → connects to a single application server
# SAP_CONN_TYPE=msgserver → connects via message server (load-balanced)
SAP_CONN_TYPE=msgserver

# ── Authentication mode ───────────────────────────────────────────────────────
# SAP_AUTH_MODE=snc      → Windows SNC/SSO via sapcrypto (no password stored)
# SAP_AUTH_MODE=password → explicit user/password
SAP_AUTH_MODE=snc

# ── Message-server connection (SAP_CONN_TYPE=msgserver) ───────────────────────
SAP_MSHOST=your-sap-host.corp.local
SAP_MSSERV=3601
SAP_SYSID=SID
SAP_GROUP=SPACE

# ── Direct connection (SAP_CONN_TYPE=direct) ──────────────────────────────────
# SAP_HOST=your-sap-host.corp.local
# SAP_SYSNR=00

# ── Shared ────────────────────────────────────────────────────────────────────
SAP_CLIENT=100
SAP_LANG=EN

# ── SNC / SSO (SAP_AUTH_MODE=snc) ────────────────────────────────────────────
SAP_SNC_NAME=p/secude:CN=SID, O=Corp, C=US
SAP_SNC_QOP=9
# Full path to sapcrypto.dll shipped with SAP GUI
SNC_LIB=C:\Program Files\SAP\FrontEnd\SecureLogin\lib\sapcrypto.dll

# ── Password auth (SAP_AUTH_MODE=password) ───────────────────────────────────
# SAP_USER=RFC_USER
# SAP_PASSWORD=changeme

# ── App settings ─────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
